/#==============================================================================
  Testing task spawning with struct methods that access @attr and call builtins.
  This exercises the VM/interpreter boundary inside spawned task threads.
 ==============================================================================#/
require "task"

@tester::test("tasks: struct methods inside spawned tasks")
fn test_tasks_struct()
  struct Accumulator
    fn new()
      @total = 0
      @items = []
    end

    fn add(n)
      @total += n
      @items.push(n)
    end

    fn total() @total end
    fn count() @items.size() end

    fn summary()
      # builtins on @attr inside struct method — key VM fallback path
      mean = @total.to_float() / @items.size()
      "${@items.size()} items, total=${@total}, mean=${mean}"
    end
  end

  # A1: struct ops inside a spawned task return the correct value
  id = task::spawn(with () do
    acc = Accumulator.new()
    for i in [1 to 10] do
      acc.add(i)
    end
    [acc.total(), acc.count(), acc.summary()]
  end, [])

  result = await(id)
  tester::assert(result[0] == 55,                             "A1: total")
  tester::assert(result[1] == 10,                             "A2: count")
  tester::assert(result[2] == "10 items, total=55, mean=5.5", "A3: summary: ${result[2]}")

  # A4-A6: multiple tasks with independent struct instances don't share state
  ids = []
  for n in [10, 20, 30] do
    tid = task::spawn(with (limit) do
      acc = Accumulator.new()
      for i in [1 to limit] do
        acc.add(i)
      end
      acc.total()
    end, [n])
    ids.push(tid)
  end

  totals = []
  for tid in ids do
    totals.push(await(tid))
  end

  tester::assert(totals[0] == 55,  "A4: task 0 total (1..10)")
  tester::assert(totals[1] == 210, "A5: task 1 total (1..20)")
  tester::assert(totals[2] == 465, "A6: task 2 total (1..30)")

  # A7: channel-based communication with struct method inside task
  ch = task::channel()

  task::spawn(with (c) do
    acc = Accumulator.new()
    acc.add(3)
    acc.add(7)
    acc.add(10)
    c.send(acc.summary())
    c.close()
  end, [ch])

  msg = ch.recv()
  tester::assert(msg == "3 items, total=20, mean=6.666666666666667", "A7: channel msg: ${msg}")
end
