/# ==============================================================================
   Testing try-finally.
  ============================================================================== #/
@tester::test("try-finally")
fn test_try_finally()
  a = 0, b = 0

  try
    a += 1
    println "${1 / 0}" # throws DivideByZeroError
    a += 1
  finally
    b += 1
  end

  tester::assert(a == 1)
  tester::assert(b == 1)
end
