/# ==============================================================================
   Testing the protobuf stdlib module: encode, decode, field types, nested
   messages, repeated fields, file I/O, and the field() helper.
  ============================================================================== #/
require "protobuf"

tester::register_test("protobuf", with do
  # ---- A: scalar field types ----

  scalar_schema = {
    1:  { name: "i32",   type: "int32"   },
    2:  { name: "i64",   type: "int64"   },
    3:  { name: "u32",   type: "uint32"  },
    4:  { name: "u64",   type: "uint64"  },
    5:  { name: "s32",   type: "sint32"  },
    6:  { name: "s64",   type: "sint64"  },
    7:  { name: "f32",   type: "fixed32" },
    8:  { name: "f64",   type: "fixed64" },
    9:  { name: "sf32",  type: "sfixed32" },
    10: { name: "sf64",  type: "sfixed64" },
    11: { name: "fl",    type: "float"   },
    12: { name: "dbl",   type: "double"  },
    13: { name: "flag",  type: "bool"    },
    14: { name: "str",   type: "string"  },
    15: { name: "raw",   type: "bytes"   },
  }

  scalars = {
    i32:  42,
    i64:  9876543210,
    u32:  4000000000,
    u64:  9000000000,
    s32:  -100,
    s64:  -999999999,
    f32:  1234,
    f64:  9876543,
    sf32: -256,
    sf64: -9876543,
    fl:   3.14,
    dbl:  2.718281828,
    flag: true,
    str:  "hello",
    raw:  "world".to_bytes(),
  }

  enc = protobuf::encode(scalar_schema, scalars)
  dec = protobuf::decode(scalar_schema, enc)

  tester::assert(dec["i32"]  == 42,          "A1: int32 roundtrip")
  tester::assert(dec["i64"]  == 9876543210,  "A2: int64 roundtrip")
  tester::assert(dec["u32"]  == 4000000000,  "A3: uint32 roundtrip")
  tester::assert(dec["u64"]  == 9000000000,  "A4: uint64 roundtrip")
  tester::assert(dec["s32"]  == -100,        "A5: sint32 roundtrip (negative)")
  tester::assert(dec["s64"]  == -999999999,  "A6: sint64 roundtrip (negative)")
  tester::assert(dec["f32"]  == 1234,        "A7: fixed32 roundtrip")
  tester::assert(dec["f64"]  == 9876543,     "A8: fixed64 roundtrip")
  tester::assert(dec["sf32"] == -256,        "A9: sfixed32 roundtrip (negative)")
  tester::assert(dec["sf64"] == -9876543,    "A10: sfixed64 roundtrip (negative)")
  tester::assert(dec["flag"] == true,        "A11: bool roundtrip")
  tester::assert(dec["str"]  == "hello",     "A12: string roundtrip")

  # float is lossy — check within tolerance
  fl_ok = math::abs(dec["fl"] - 3.14) < 0.0001
  tester::assert(fl_ok,                      "A13: float roundtrip (within tolerance)")

  # double is more precise
  dbl_ok = math::abs(dec["dbl"] - 2.718281828) < 0.000000001
  tester::assert(dbl_ok,                     "A14: double roundtrip (within tolerance)")

  # bytes field decodes to bytes type
  tester::assert(dec["raw"].is_a(bytes),     "A15: bytes field type is bytes")

  # ---- B: sint32/sint64 zigzag ----

  zz_schema = {
    1: { name: "a", type: "sint32" },
    2: { name: "b", type: "sint64" },
    3: { name: "c", type: "sint32" },
    4: { name: "d", type: "sint64" },
  }

  zz_data = { a: 0, b: 1, c: -1, d: -2147483648 }
  zz_enc  = protobuf::encode(zz_schema, zz_data)
  zz_dec  = protobuf::decode(zz_schema, zz_enc)

  tester::assert(zz_dec["a"] == 0,           "B1: sint32 zero")
  tester::assert(zz_dec["b"] == 1,           "B2: sint64 positive")
  tester::assert(zz_dec["c"] == -1,          "B3: sint32 -1 zigzag")
  tester::assert(zz_dec["d"] == -2147483648, "B4: sint64 large negative")

  # ---- C: bool variants ----

  bool_schema = {
    1: { name: "t", type: "bool" },
    2: { name: "f", type: "bool" },
  }

  bool_enc = protobuf::encode(bool_schema, { t: true, f: false })
  bool_dec = protobuf::decode(bool_schema, bool_enc)

  tester::assert(bool_dec["t"] == true,  "C1: bool true roundtrip")
  tester::assert(bool_dec["f"] == false, "C2: bool false roundtrip")

  # ---- D: string edge cases ----

  str_schema = {
    1: { name: "empty", type: "string" },
    2: { name: "utf8",  type: "string" },
    3: { name: "multi", type: "string" },
  }

  str_enc = protobuf::encode(str_schema, {
    empty: "",
    utf8:  "kiwi 🥝",
    multi: "line1\nline2\ttab",
  })
  str_dec = protobuf::decode(str_schema, str_enc)

  tester::assert(str_dec["empty"] == "",              "D1: empty string roundtrip")
  tester::assert(str_dec["utf8"]  == "kiwi 🥝",      "D2: UTF-8 emoji string roundtrip")
  tester::assert(str_dec["multi"] == "line1\nline2\ttab", "D3: string with newline and tab")

  # ---- E: repeated fields ----

  rep_schema = {
    1: { name: "nums",  type: "int32",  repeated: true },
    2: { name: "words", type: "string", repeated: true },
    3: { name: "empty", type: "string", repeated: true },
  }

  rep_data = { nums: [1, 2, 3, 100, -5], words: ["alpha", "beta", "gamma"], empty: [] }
  rep_enc  = protobuf::encode(rep_schema, rep_data)
  rep_dec  = protobuf::decode(rep_schema, rep_enc)

  tester::assert(rep_dec["nums"].size() == 5,   "E1: repeated int32 count")
  tester::assert(rep_dec["nums"][0] == 1,       "E2: repeated int32 first")
  tester::assert(rep_dec["nums"][4] == -5,      "E3: repeated int32 last (negative)")
  tester::assert(rep_dec["words"].size() == 3,  "E4: repeated string count")
  tester::assert(rep_dec["words"][0] == "alpha","E5: repeated string first")
  tester::assert(rep_dec["words"][2] == "gamma","E6: repeated string last")
  tester::assert(rep_dec["empty"].size() == 0,  "E7: repeated empty field is empty list")

  # ---- F: nested messages ----

  addr_schema = {
    1: { name: "street", type: "string" },
    2: { name: "city",   type: "string" },
    3: { name: "zip",    type: "int32"  },
  }

  person_schema = {
    1: { name: "name",    type: "string" },
    2: { name: "age",     type: "int32"  },
    3: { name: "address", type: "message", schema: addr_schema },
  }

  person = {
    name: "Alice",
    age:  30,
    address: { street: "123 Elm St", city: "Kiwi Town", zip: 99999 },
  }

  p_enc = protobuf::encode(person_schema, person)
  p_dec = protobuf::decode(person_schema, p_enc)
  addr  = p_dec["address"]

  tester::assert(p_dec["name"]   == "Alice",       "F1: nested — outer string field")
  tester::assert(p_dec["age"]    == 30,            "F2: nested — outer int32 field")
  tester::assert(addr["street"]  == "123 Elm St",  "F3: nested — inner string field")
  tester::assert(addr["city"]    == "Kiwi Town",   "F4: nested — inner city")
  tester::assert(addr["zip"]     == 99999,         "F5: nested — inner int32 field")

  # ---- G: missing fields are omitted; unknown fields are skipped ----

  sparse_schema = {
    1: { name: "x", type: "int32" },
    2: { name: "y", type: "int32" },
  }

  # encode only x, omit y
  sp_enc = protobuf::encode(sparse_schema, { x: 7 })
  sp_dec = protobuf::decode(sparse_schema, sp_enc)

  tester::assert(sp_dec["x"] == 7,          "G1: present field decoded correctly")
  tester::assert(!sp_dec.has_key("y"),       "G2: absent field not in result")

  # ---- H: encode/decode returns correct binary size ----

  # A single int32 field=1, value=1 encodes to tag 0x08 + varint 0x01 = 2 bytes
  tiny_schema = { 1: { name: "n", type: "int32" } }
  tiny_enc = protobuf::encode(tiny_schema, { n: 1 })
  tester::assert(tiny_enc.size() == 2, "H1: minimal int32 message is 2 bytes")

  # ---- I: file roundtrip ----

  tmp = fio::tmpfile()
  fi_schema = {
    1: { name: "id",   type: "int32"  },
    2: { name: "name", type: "string" },
  }
  fi_data = { id: 77, name: "filetest" }
  protobuf::encode_file(fi_schema, fi_data, tmp)
  fi_dec = protobuf::decode_file(fi_schema, tmp)
  fio::remove(tmp)

  tester::assert(fi_dec["id"]   == 77,         "I1: encode_file/decode_file — int32")
  tester::assert(fi_dec["name"] == "filetest",  "I2: encode_file/decode_file — string")

  # decode_file throws on missing file
  caught = false
  try
    protobuf::decode_file(fi_schema, "/no/such/file.pb")
  catch (err)
    caught = true
  end
  tester::assert(caught, "I3: decode_file throws on missing file")

  # ---- J: protobuf::field() helper ----

  fh_schema = {
    1: protobuf::field("x", "sint32"),
    2: protobuf::field("tags", "string", true),
    3: protobuf::field("score", "double"),
  }
  fh_data = { x: -42, tags: ["a", "b", "c"], score: 1.5 }
  fh_enc  = protobuf::encode(fh_schema, fh_data)
  fh_dec  = protobuf::decode(fh_schema, fh_enc)

  tester::assert(fh_dec["x"]          == -42,  "J1: field() helper — sint32")
  tester::assert(fh_dec["tags"].size() == 3,    "J2: field() helper — repeated count")
  tester::assert(fh_dec["tags"][1]    == "b",   "J3: field() helper — repeated element")
  score_ok = math::abs(fh_dec["score"] - 1.5) < 0.0001
  tester::assert(score_ok,                      "J4: field() helper — double")

  # field() with nested schema
  inner_schema = { 1: { name: "v", type: "int32" } }
  fh2_schema = {
    1: protobuf::field("msg", "message", false, inner_schema),
  }
  fh2_enc = protobuf::encode(fh2_schema, { msg: { v: 99 } })
  fh2_dec = protobuf::decode(fh2_schema, fh2_enc)
  tester::assert(fh2_dec["msg"]["v"] == 99, "J5: field() helper with nested schema")
end)
