/# ==============================================================================
   Testing package definitions, exports, and inter-function calls.
  ============================================================================== #/
@tester::test("packages")
fn test_packages()
  # basic package with multiple functions
  package strutils
    fn replicate(s, n)
      result = ""
      i = 0
      while i < n do
        result += s
        i += 1
      end
      return result
    end

    fn shout(s)
      return s.uppercase() + "!!!"
    end

    fn wrap(s, open, close)
      return open + s + close
    end
  end
  export "strutils"

  tester::assert(strutils::replicate("ab", 3) == "ababab",     "A1: package function replicate")
  tester::assert(strutils::shout("hello") == "HELLO!!!",       "A2: package function shout")
  tester::assert(strutils::wrap("x", "[", "]") == "[x]",       "A3: package function wrap")

  # package function calling another function in the same package
  package counter
    fn increment(n)
      return n + 1
    end

    fn add_n(value, n)
      result = value
      i = 0
      while i < n do
        result = counter::increment(result)
        i += 1
      end
      return result
    end
  end
  export "counter"

  tester::assert(counter::increment(9) == 10,    "A4: package function increment")
  tester::assert(counter::add_n(0, 5) == 5,      "A5: package function calling sibling")
  tester::assert(counter::add_n(10, 3) == 13,    "A6: package function calling sibling with args")

  # two independent packages don't interfere
  package pkg_a
    fn greet()
      return "hello from a"
    end
  end
  export "pkg_a"

  package pkg_b
    fn greet()
      return "hello from b"
    end
  end
  export "pkg_b"

  tester::assert(pkg_a::greet() == "hello from a", "A7: independent packages don't interfere (a)")
  tester::assert(pkg_b::greet() == "hello from b", "A8: independent packages don't interfere (b)")

  # import-as-variable: `pkg = import "name"` returns a package ref
  pkg = import "strutils"
  tester::assert(pkg.replicate("ab", 3) == "ababab", "B1: import-as-var method call")
  tester::assert(pkg.shout("hello") == "HELLO!!!",   "B2: import-as-var second method")
  tester::assert(pkg.wrap("x", "[", "]") == "[x]",   "B3: import-as-var third method")

  # :: syntax still works alongside the variable ref
  tester::assert(strutils::replicate("x", 2) == "xx", "B4: :: syntax unaffected by import-as-var")

  # re-import is idempotent — returns a fresh ref to same package
  pkg2 = import "strutils"
  tester::assert(pkg2.shout("hi") == "HI!!!", "B5: re-import idempotent")

  # package ref passed as a function argument
  fn call_shout(p, s)
    return p.shout(s)
  end
  tester::assert(call_shout(pkg, "world") == "WORLD!!!", "B6: package ref as argument")

  # name collision: overwriting the variable does not affect :: resolution
  pkg = "overwritten"
  tester::assert(strutils::shout("ok") == "OK!!!", "B7: :: unaffected after var overwrite")
end
