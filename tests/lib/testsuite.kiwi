package testsuite
  fn __version__()
    "0.0.2"
  end
end

var (unit_tests: list = [
  # Language fundamentals
  "var_declaration",
  "constants",
  "assignments",
  "operators",
  "operator_overloads",
  "truthiness",
  "null_coalesce",
  "unpacking",

  # Type system
  "nulls",
  "type_checking",
  "bytestrings",

  # Collections & data types
  "strings",
  "lists",
  "sets",
  "heaps",
  "hashmaps",
  "dates",

  # Control flow & scoping
  "loops",
  "scoping",
  "chained_access",

  # Functions & callables
  "lambdas",
  "decorators",
  "generators",
  "iterators",

  # Error handling
  "try_finally",
  "try_catch_finally",
  "nested_try",
  "error_pkg",

  # Object-oriented programming
  "structs",
  "static_vars",
  "abstract_structs",

  # Standard library & builtins
  "builtins",
  "standard_library",

  # Module system
  "case_when",
  "packages",
  "events",

  # Crypto
  "md5",
  "sha224",
  "sha256",

  # Data formats
  "regex",
  "dotenv",
  "xml",
  "protobuf",

  # Storage & I/O
  "sqlite",
  "compression",
  "http"
])

for unit_test in unit_tests do
  include "suite/${unit_test}"
end

export "testsuite"